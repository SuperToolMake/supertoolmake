{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@supertoolmake/*": [
        "../*/src/index.ts",
        "../*/src/index.js",
        "../*",
        "../../node_modules/@supertoolmake/*"
      ],
      "assets/*": ["assets/*"],
      "@/*": ["src/*"]
    }
  },
  "exclude": []
}
