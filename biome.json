{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "packages/**/*.js",
      "packages/**/*.ts",
      "packages/**/*.svelte",
      "!**/node_modules",
      "!**/dist",
      "!**/public",
      "!**/bundle.js",
      "!**/coverage",
      "!packages/server/builder",
      "!packages/server/client",
      "!packages/builder/.routify",
      "!packages/sdk/sdk",
      "!**/*.ivm.bundle.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "error",
        "noDoubleEquals": "off",
        "noExplicitAny": "off",
        "noGlobalAssign": "off",
        "noImplicitAnyLet": "off",
        "noImportAssign": "warn",
        "noNonNullAssertedOptionalChain": "error",
        "noThenProperty": "off",
        "useIterableCallbackReturn": "off",
        "noConfusingVoidType": "error",
        "noGlobalIsNan": "error",
        "useDefaultSwitchClauseLast": "error",
        "noDocumentCookie": "off",
        "noTemplateCurlyInString": "off",
        "useIsArray": "error"
      },
      "correctness": {
        "noConstructorReturn": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noSelfAssign": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedPrivateClassMembers": "error",
        "useParseIntRadix": "off"
      },
      "security": {
        "noGlobalEval": "off"
      },
      "complexity": {
        "useOptionalChain": "error",
        "noBannedTypes": "off",
        "noStaticOnlyClass": "off",
        "noCommaOperator": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error",
        "useConst": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noDynamicNamespaceImportAccess": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/**/*.svelte"],
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      },
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
